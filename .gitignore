.venv/
__pycache__/
*.pyc
*.egg-info/
*.swp
dist/
build/

# Normative DB build outputs (regenerate via scripts/build_norms.py)
norms_output/
norms_output_*/

# Generated BA/DK surface label pickles (regenerate via build_{ba,dk}_labels.py)
open_normative/data/source/ba_labels_*.pkl
open_normative/data/source/dk_labels_*.pkl

# Local tooling / scratch (not part of the source tree)
.claude/
cmd
re-analyze.sh
npz_integration_prompt.md

# Per-user AWS config (ship aws-config.example.yaml instead)
aws-config.yaml
.envrc

# Personal run playbook (per-user commands, pre-filled with bucket etc.)
RUN.md

# Terraform local state & plans (only in infra/aws/)
infra/aws/.terraform/
infra/aws/.terraform.lock.hcl
infra/aws/terraform.tfstate*
infra/aws/terraform.tfvars
infra/aws/*.tfplan
